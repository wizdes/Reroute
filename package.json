{
  "name": "reroute",
  "version": "0.1.0",
  "description": "Chrome MV3 extension: redirect URLs with simple wildcard rules, and test them before you save.",
  "type": "module",
  "license": "MIT",
  "author": "Yi Li",
  "homepage": "https://github.com/wizdes/Reroute#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/wizdes/Reroute.git"
  },
  "bugs": {
    "url": "https://github.com/wizdes/Reroute/issues"
  },
  "keywords": [
    "chrome-extension",
    "manifest-v3",
    "redirect",
    "url-rewrite",
    "declarativeNetRequest",
    "redirector"
  ],
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "test:ui": "node test/ui.mjs",
    "test:browser": "node test/browser.mjs",
    "icons": "node tools/gen-icons.mjs",
    "package": "node tools/package.mjs",
    "store-assets": "node store-assets/render.mjs"
  },
  "devDependencies": {
    "playwright": "^1.49.0",
    "re2-wasm": "^1.0.2"
